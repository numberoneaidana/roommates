# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

# Project URL  (e.g. https://abcdefghij.supabase.co)
SUPABASE_URL=process.env.SUPABASE_URL;

# Anon / public key  (safe to use in browser, respects RLS)
SUPABASE_ANON_KEY=process.env.SUPABASE_ANON_KEY;


# Service Role key  (NEVER expose in frontend; bypasses RLS)
SUPABASE_SERVICE_KEY=process.env.SUPABASE_SERVICE_KEY;

# ── JWT (your own tokens for the API) ────────────────────────────────────────
# Generate a strong secret:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=8b5fb1267ba07cbb70d844eac3b40d800d8f2a2409f06fbe94ffa9a028364fd9a29f99f36fcfd2d38af03c289df4948ffdac5823f9815061e531db5da864a8da
JWT_EXPIRES_IN=30d

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=https://roommatch-weld.vercel.app
